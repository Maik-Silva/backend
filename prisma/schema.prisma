datasource db {
  provider = "postgresql" // ou "mysql" / "sqlite" dependendo do seu ambiente
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-generator"
}

model Administradores {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  senha_hash String
}

model Nutricionistas {
  id                         Int         @id @default(autoincrement())
  nome                       String
  email                      String      @unique
  senha_hash                 String
  crn                        String?
  sexo                       String // "Feminino" ou "Masculino"
  plano                      String      @default("free") // ex: "free", "premium"
  ativo                      Boolean     @default(true)
  limite_pacientes           Int         @default(5)
  especialidade              String?
  whatsapp                   String?
  instagram                  String?
  logo_url                   String?
  bloquear_grupos_diferentes Boolean     @default(false)
  
  // Relacionamentos
  pacientes                  Pacientes[]
}

model Pacientes {
  id               Int            @id @default(autoincrement())
  nutricionista_id Int
  nome             String
  email            String         @unique
  telefone         String // Salvo apenas com números (\D removidos)
  senha_hash       String
  data_nascimento  DateTime
  sexo             String // "Feminino" ou "Masculino"
  observacoes      String?

  // Relacionamentos
  nutricionista    Nutricionistas @relation(fields: [nutricionista_id], references: [id], onDelete: Cascade)
  logs_acesso      Logs_acesso[]
}

model Logs_acesso {
  id          Int       @id @default(autoincrement())
  paciente_id Int
  data_acesso DateTime  @default(now())

  // Relacionamentos
  paciente    Pacientes @relation(fields: [paciente_id], references: [id], onDelete: Cascade)
}

model Banco_equivale {
  id              Int    @id @default(autoincrement())
  Alimento        String // Buscado via .contains()
  Energia__Kcal_  Float  // Mapeado como float/decimal para cálculos calóricos
  grupo           String // Usado na validação de categorias iguais/diferentes

  @@map("banco_equivale") // Garante que respeite a tabela unificada em minúsculo se necessário
}
